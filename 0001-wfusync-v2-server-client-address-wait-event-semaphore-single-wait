+static void wfusync_dump_stats(void)
+{
+    if (wfusync_stats_enabled == -1)
+    {
+        const char *env = getenv( "WINEWFUSYNC_STATS" );
+        wfusync_stats_enabled = (env && atoi( env )) ? 1 : 0;
+    }
+
+    if (wfusync_stats_enabled)
+    {
