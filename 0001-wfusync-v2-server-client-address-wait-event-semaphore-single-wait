+static void wfusync_wake_waiters( unsigned int shm_idx )
+{
+    SERVER_START_REQ( wake_wfusync_waiters )
+    {
+        req->shm_idx = shm_idx;
+        wine_server_call( req );
+    }
+    SERVER_END_REQ;
+}
