+#define WFUSYNC_TYPE_MASK         0x3fff
+#define WFUSYNC_MULTI_WAITERS     0x4000
+#define WFUSYNC_SERVER_WAITERS    0x8000
+
+#ifdef __APPLE__
+#define UL_COMPARE_AND_WAIT        1
