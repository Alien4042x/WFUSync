+static BOOL wfusync_atomic_compare_exchange( int *addr, int expected, int desired )
+{
+    return __atomic_compare_exchange_n( addr, &expected, desired, FALSE, __ATOMIC_SEQ_CST, __ATOMIC_SEQ_CST );
+}
